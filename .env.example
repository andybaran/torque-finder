# --- Anthropic (extraction) ---
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- Voyage AI (embeddings) ---
VOYAGE_API_KEY=pa-...
VOYAGE_MODEL=voyage-3

# --- Cloudflare R2 (object storage, S3-compatible) ---
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=parts-lookup
# Optional: public base URL for serving page PNGs (custom domain on the bucket)
R2_PUBLIC_BASE_URL=https://assets.example.com

# --- Postgres (Railway managed; pgvector enabled) ---
# asyncpg dialect required for the runtime app; alembic uses sync via psycopg if needed.
DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/parts_lookup

# --- OpenTelemetry (Grafana Cloud OTLP/HTTP) ---
OTEL_EXPORTER_OTLP_ENDPOINT=https://otlp-gateway-prod-us-east-0.grafana.net/otlp
OTEL_EXPORTER_OTLP_HEADERS=Authorization=Basic%20...
OTEL_SERVICE_NAME=parts-lookup

# --- Sentry ---
SENTRY_DSN=

# --- App ---
APP_ENV=local
LOG_LEVEL=INFO
RETRIEVAL_TOP_K=3
